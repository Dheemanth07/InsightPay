// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Model
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  balance   Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentTransactions      Transaction[]  @relation("SentTransactions")
  receivedTransactions  Transaction[]  @relation("ReceivedTransactions")
  cards                 Card[]
  categories            Category[]
  subscriptions         Subscription[]
  splitRequestsSent     SplitRequest[] @relation("SplitRequester")
  splitRequestsReceived SplitRequest[] @relation("SplitPayer")
}

// Transaction Model
model Transaction {
  id Int @id @default(autoincrement())

  reference String? @unique
  amount    Decimal

  type   TxnType
  method TxnMethod @default(MANUAL)
  status TxnStatus

  fromUserId Int?
  fromUser   User? @relation("SentTransactions", fields: [fromUserId], references: [id])

  toUserId Int?
  toUser   User? @relation("ReceivedTransactions", fields: [toUserId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  qrExpiresAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime?
  splits    SplitRequest[]

  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@index([reference])
  @@index([categoryId])
}

// Card Model
model Card {
  id          String   @id @default(uuid())
  userId      Int
  cardToken   String   @unique
  last4       String
  brand       String
  issuerBank  String   @default("HDFC")
  expiryMonth Int
  expiryYear  Int
  createdAt   DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id])
  subscriptions Subscription[]
}

// Category Model
model Category {
  id   String       @id @default(uuid())
  name String
  type CategoryType

  isDefault Boolean @default(false)
  isSystem  Boolean @default(false)

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

// Transaction Type Enum
enum TxnType {
  DEPOSIT
  TRANSFER
  WITHDRAWAL
}

enum TxnMethod {
  MANUAL
  QR_CODE
  SYSTEM
}

// Transaction Status Enum
enum TxnStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

// Category Type Enum
enum CategoryType {
  INCOME
  EXPENSE
}

// Subscription Model
model Subscription {
  id              String       @id @default(uuid())   
  userId          Int
  cardId          String
  merchantName    String
  amount          Decimal
  billingCycle    BillingCycle
  nextBillingDate DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([cardId])
  @@index([nextBillingDate])
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// SplitRequest Model
model SplitRequest {
  id            String      @id @default(uuid())
  transactionId Int
  requesterId   Int
  payerId       Int
  amountOwed    Decimal
  status        SplitStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])
  requester   User        @relation("SplitRequester", fields: [requesterId], references: [id])
  payer       User        @relation("SplitPayer", fields: [payerId], references: [id])

  @@index([transactionId])
  @@index([requesterId])
  @@index([payerId])
}

enum SplitStatus {
  PENDING
  PAID
  REJECTED
}
